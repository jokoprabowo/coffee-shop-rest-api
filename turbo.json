{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"], 
      "outputs": [],
      "cache": false
    },
    "test:api": {
      "dependsOn": ["^build"], 
      "outputs": [],
      "cache": false
    },
    "test:consumer": {
      "dependsOn": ["^build"], 
      "outputs": [],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "migrate:up:dev": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "migrate:down:dev": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "migrate:up:test": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "migrate:down:test": {
      "cache": false,
      "env": ["DATABASE_URL"]
    }
  }
}
