{
  "name": "coffee-shop-rest-api",
  "private": true,
  "packageManager": "npm@11.12.1",
  "version": "1.0.0",
  "description": "The Coffee Shop REST API is a backend service designed to manage a coffee shop’s operations, built with **Express.js**, **TypeScript**, **PostgreSQL**, and **Docker**. It provides endpoints to handle customers, menu items, orders, carts, and authentication, enabling smooth integration with frontend or mobile applications.",
  "main": "index.js",
  "workspaces": [
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "start": "turbo run start",
    "lint": "eslint .",
    "test:api": "turbo run test --filter=@project/api",
    "test:consumer": "turbo run test --filter=@project/consumer",
    "migrate:up:dev": "turbo run migrate:up:dev --filter=@project/api",
    "migrate:down:dev": "turbo run migrate:down:dev --filter=@project/api",
    "migrate:up:test": "turbo run migrate:up:test --filter=@project/api",
    "migrate:down:test": "turbo run migrate:down:test --filter=@project/api"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "turbo": "^2.8.21",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}
