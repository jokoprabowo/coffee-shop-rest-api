{
  "name": "@project/api",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "cross-env NODE_ENV=test jest --runInBand --detectOpenHandles --forceExit",
    "build": "tsc -p tsconfig.json",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "dev": "cross-env NODE_ENV=development nodemon",
    "start:docker": "cross-env NODE_ENV=production npm run migrate:up && node dist/server.js",
    "migrate": "node-pg-migrate -j ts",
    "migrate:up": "cross-env NODE_ENV=production npx node-pg-migrate up",
    "migrate:down": "cross-env NODE_ENV=production npx node-pg-migrate down 9",
    "migrate:up:dev": "npx dotenv -e ../../.env.development -- npx node-pg-migrate up",
    "migrate:down:dev": "npx dotenv -e ../../.env.development -- npx node-pg-migrate down 9",
    "migrate:up:test": "npx dotenv -e ../../.env.test -- npx node-pg-migrate up",
    "migrate:down:test": "npx dotenv -e ../../.env.test -- npx node-pg-migrate down 9"
  },
  "keywords": [
    "node",
    "express",
    "rest api",
    "typescript"
  ],
  "author": "Joko Prabowo",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@project/shared": "^1.0.0",
    "amqplib": "^1.0.2",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "joi": "^18.1.1",
    "jsonwebtoken": "^9.0.3",
    "midtrans-client": "^1.4.3",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "rate-limit-redis": "^4.3.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/midtrans-client": "^1.4.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "ioredis-mock": "^8.13.1",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
